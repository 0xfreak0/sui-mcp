# All variables are optional. Defaults connect to Sui mainnet public endpoints.

# Network: mainnet (default), testnet, devnet
SUI_NETWORK=mainnet

# Override default RPC endpoints
SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io
SUI_GRAPHQL_URL=https://graphql.mainnet.sui.io/graphql

# Move Registry (MVR) base URL — defaults follow SUI_NETWORK
# (mainnet → mainnet.mvr.mystenlabs.com/v1, testnet → testnet.mvr.mystenlabs.com/v1).
# Devnet has no MVR endpoint; MVR tools will return an error.
# SUI_MVR_URL=https://mainnet.mvr.mystenlabs.com/v1

# Path to Revela move-decompiler binary (for decompile_module tool)
# SUI_DECOMPILER_PATH=/path/to/move-decompiler
