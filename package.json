{
  "name": "sui-mcp",
  "version": "0.1.0",
  "description": "MCP server for querying the Sui blockchain",
  "type": "module",
  "bin": {
    "sui-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/data dist/",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "generate": "echo 'No codegen needed - using @mysten/sui SDK'",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:decompiler": "bash scripts/build-decompiler.sh"
  },
  "keywords": [
    "sui",
    "mcp",
    "blockchain",
    "model-context-protocol",
    "defi",
    "nft",
    "grpc",
    "graphql"
  ],
  "author": "0xfreak0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xfreak0/sui-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/0xfreak0/sui-mcp/issues"
  },
  "homepage": "https://github.com/0xfreak0/sui-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@mysten/sui": "^2.3.1",
    "@protobuf-ts/grpc-transport": "^2.11.1",
    "graphql-request": "^7.1.2",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
